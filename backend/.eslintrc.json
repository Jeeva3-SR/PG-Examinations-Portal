{
  "env": {
    "node": true,
    "es2021": true
  },
  "extends": ["eslint:recommended"],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "script"
  },
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-console": "off",
    "semi": ["warn", "always"],
    "quotes": ["warn", "single", { "avoidEscape": true }],
    "comma-dangle": ["warn", "always-multiline"],
    "no-undef": "error"
  },
  "globals": {
    "require": "readonly",
    "module": "readonly",
    "__dirname": "readonly",
    "process": "readonly",
    "exports": "readonly"
  }
}
