# =============================================================================
# PG Examinations Portal — Environment Variables
# Copy this to .env and fill in your values
# =============================================================================

# ── Server ──────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
JWT_SECRET=change-this-to-a-random-secret-in-production

# ── MongoDB ─────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://127.0.0.1:27017/exam-management

# ── Frontend URL (used for password reset links in emails) ─────────────────
FRONTEND_URL=http://localhost:3000

# ── AWS S3 (for student Excel uploads) ─────────────────────────────────────
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=ap-southeast-2
S3_BUCKET_NAME=your-bucket-name

# ── Email (optional — needed for password reset) ───────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=PG Exam Portal <noreply@example.com>
