{
  "openapi": "3.0.0",
  "info": {
    "title": "PG Examinations Portal API",
    "version": "1.0.0",
    "description": "Minimal OpenAPI spec for key endpoints used by the portal (sessions, student inputs, reports)."
  },
  "servers": [
    { "url": "http://localhost:5000", "description": "Local development server" }
  ],
  "paths": {
    "/api/login": {
      "post": {
        "summary": "Authenticate user",
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "properties": { "email": { "type": "string" }, "password": { "type": "string" } }, "required": ["email","password"] } } } },
        "responses": { "200": { "description": "Authentication successful", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AuthResponse" } } } }, "401": { "description": "Invalid credentials" } }
      }
    },
    "/api/register": {
      "post": {
        "summary": "Register user",
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/UserCreate" } } } },
        "responses": { "201": { "description": "User created" } }
      }
    },
    "/api/profile": {
      "get": { "summary": "Get current user profile", "responses": { "200": { "description": "User profile", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/User" } } } } } ,
      "patch": { "summary": "Update current user profile", "requestBody": { "content": { "application/json": { "schema": { "$ref": "#/components/schemas/UserUpdate" } } } }, "responses": { "200": { "description": "Updated" } } }
    },
    "/api/users": {
      "get": { "summary": "List users (admin)", "responses": { "200": { "description": "Array of users", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/User" } } } } } }
    },
    "/api/users/{id}/status": {
      "patch": { "summary": "Activate/deactivate user (admin)", "parameters": [ { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } } ], "requestBody": { "content": { "application/json": { "schema": { "type": "object", "properties": { "isActive": { "type": "boolean" } } } } } }, "responses": { "200": { "description": "Status updated" } } }
    },
    "/api/sessions": {
      "get": { "summary": "List sessions", "responses": { "200": { "description": "Array of sessions", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Session" } } } } } },
      "post": { "summary": "Create session", "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SessionCreate" } } } }, "responses": { "201": { "description": "Created" } } }
    },
    "/api/sessions/upload": {
      "post": { "summary": "Upload timetable (XLSX/CSV)", "requestBody": { "content": { "multipart/form-data": { "schema": { "type": "object", "properties": { "file": { "type": "string", "format": "binary" } } } } } }, "responses": { "200": { "description": "Processed" } } }
    },
    "/api/sessions/consolidated": { "get": { "summary": "Consolidated sessions", "responses": { "200": { "description": "Array", "content": { "application/json": { "schema": { "type": "array", "items": { "type": "object" } } } } } } },
    "/api/sessions/count": { "get": { "summary": "Session count", "responses": { "200": { "description": "Count", "content": { "application/json": { "schema": { "type": "object", "properties": { "sessionCount": { "type": "integer" } } } } } } } },
    "/api/student-inputs": {
      "get": { "summary": "List student inputs", "responses": { "200": { "description": "Array", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/StudentInput" } } } } } },
      "post": { "summary": "Create student input", "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/StudentInputCreate" } } } }, "responses": { "201": { "description": "Created" } } }
    },
    "/api/student-inputs/total-ceg": { "get": { "summary": "Total CEG", "responses": { "200": { "description": "Total CEG", "content": { "application/json": { "schema": { "type": "object", "properties": { "totalCeg": { "type": "integer" } } } } } } } },
    "/api/assigned-qpsetters": { "get": { "summary": "List assigned QP setters", "responses": { "200": { "description": "Array" } } }, "post": { "summary": "Assign QP setter", "responses": { "201": { "description": "Assigned" } } } , 
    "/api/assigned-qpsetters/{id}": { "delete": { "summary": "Unassign QP setter", "parameters": [{ "name": "id","in":"path","required":true,"schema":{"type":"string"}}], "responses": { "200": { "description": "Deleted" } } } },
    "/api/qporders": { "get": { "summary": "List QP orders" }, "post": { "summary": "Create QP order" } },
    "/api/letters": { "get": { "summary": "List letters" }, "post": { "summary": "Create/generate letter" } },
    "/api/claims": { "get": { "summary": "List claims" }, "post": { "summary": "Create claim" }, "patch": { "summary": "Update claim" } },
    "/api/duties": { "get": { "summary": "List duties" }, "post": { "summary": "Create/generate duties" } },
    "/api/seating-arrangement": { "post": { "summary": "Generate seating arrangement for a session" } }
  },
  "components": {
    "schemas": {
      "Session": {
        "type": "object",
        "properties": {
          "_id": { "type": "string" },
          "date": { "type": "string", "format": "date" },
          "day": { "type": "string" },
          "session": { "type": "string", "enum": ["FN", "AN"] },
          "courseCode": { "type": "string" },
          "courseName": { "type": "string" },
          "specialization": { "type": "string" }
        }
      },
      "SessionCreate": {
        "type": "object",
        "required": ["date","session","courseCode","courseName","specialization"],
        "properties": {
          "date": { "type": "string", "format": "date" },
          "session": { "type": "string", "enum": ["FN", "AN"] },
          "courseCode": { "type": "string" },
          "courseName": { "type": "string" },
          "specialization": { "type": "string" }
        }
      },
      "StudentInput": {
        "type": "object",
        "properties": {
          "_id": { "type": "string" },
          "specialization": { "type": "string" },
          "courseCode": { "type": "string" },
          "courseName": { "type": "string" },
          "cegRegular": { "type": "integer" },
          "cegArrear": { "type": "integer" },
          "mitRegular": { "type": "integer" },
          "mitArrear": { "type": "integer" },
          "totalRegular": { "type": "integer" },
          "totalArrear": { "type": "integer" },
          "total": { "type": "integer" },
          "totalCEG": { "type": "integer" },
          "totalMIT": { "type": "integer" },
          "date": { "type": "string", "format": "date" },
          "session": { "type": "string", "enum": ["FN", "AN"] }
        }
      },
      "StudentInputCreate": {
        "type": "object",
        "required": ["specialization","courseCode","courseName","date","session"],
        "properties": {
          "specialization": { "type": "string" },
          "courseCode": { "type": "string" },
          "courseName": { "type": "string" },
          "cegRegular": { "type": "integer" },
          "cegArrear": { "type": "integer" },
          "mitRegular": { "type": "integer" },
          "mitArrear": { "type": "integer" },
          "date": { "type": "string", "format": "date" },
          "session": { "type": "string", "enum": ["FN", "AN"] }
        }
      }
    ,
      "User": {
        "type": "object",
        "properties": {
          "_id": { "type": "string" },
          "name": { "type": "string" },
          "email": { "type": "string" },
          "role": { "type": "string" },
          "department": { "type": "string" },
          "isActive": { "type": "boolean" }
        }
      },
      "UserCreate": {
        "type": "object",
        "required": ["name","email","password","role"],
        "properties": {
          "name": { "type": "string" },
          "email": { "type": "string" },
          "password": { "type": "string" },
          "role": { "type": "string" },
          "department": { "type": "string" }
        }
      },
      "UserUpdate": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "department": { "type": "string" }
        }
      },
      "AuthResponse": {
        "type": "object",
        "properties": {
          "token": { "type": "string" },
          "user": { "$ref": "#/components/schemas/User" }
        }
      }
    }
  }
}
